<section id="contato" class="relative overflow-hidden bg-zinc-950 py-24 sm:py-32">
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,_rgba(99,102,241,0.28),_transparent_35%),radial-gradient(circle_at_bottom_right,_rgba(34,197,94,0.18),_transparent_30%)]"></div>

  <div class="relative mx-auto grid max-w-7xl gap-12 px-6 lg:grid-cols-2 lg:px-8">
    <div>
      <span class="inline-flex items-center rounded-full border border-white/10 bg-white/10 px-4 py-2 text-sm font-medium text-white/80 backdrop-blur">
        Fale conosco
      </span>

      <h2 class="mt-8 text-3xl font-bold tracking-tight text-white sm:text-5xl">
        Pronto para transformar sua presença digital?
      </h2>

      <p class="mt-6 text-lg leading-8 text-zinc-300">
        Preencha o formulário ou chame diretamente no WhatsApp. Vamos entender sua necessidade e indicar a melhor estrutura para o seu projeto.
      </p>

      <div class="mt-10 grid gap-4 sm:grid-cols-2">
        <div class="rounded-2xl border border-white/10 bg-white/10 p-5 backdrop-blur">
          <p class="font-semibold text-white">WhatsApp</p>
          <p class="mt-2 text-sm text-zinc-400">(19) 99999-9999</p>
        </div>

        <div class="rounded-2xl border border-white/10 bg-white/10 p-5 backdrop-blur">
          <p class="font-semibold text-white">E-mail</p>
          <p class="mt-2 text-sm text-zinc-400">contato@empresa.com.br</p>
        </div>
      </div>
    </div>

    <form
      action="https://formspree.io/f/SEU_ID"
      method="POST"
      class="rounded-[2rem] border border-white/10 bg-white p-4 sm:p-6 shadow-2xl lg:p-8"
    >
      <div class="grid gap-4 sm:gap-5">
        <div>
          <label for="nome" class="text-sm font-medium text-zinc-700">
            Nome
          </label>

          <input
            id="nome"
            name="nome"
            type="text"
            required
            placeholder="Seu nome"
            class="mt-2 w-full rounded-xl border border-zinc-200 px-4 py-3 text-sm outline-none transition focus:border-zinc-950"
          />
        </div>

        <div>
          <label for="email" class="text-sm font-medium text-zinc-700">
            E-mail
          </label>

          <input
            id="email"
            name="email"
            type="email"
            required
            placeholder="seuemail@email.com"
            class="mt-2 w-full rounded-xl border border-zinc-200 px-4 py-3 text-sm outline-none transition focus:border-zinc-950"
          />
        </div>

        <div>
          <label for="telefone" class="text-sm font-medium text-zinc-700">
            WhatsApp
          </label>

          <input
            id="telefone"
            name="telefone"
            type="tel"
            placeholder="(00) 00000-0000"
            class="mt-2 w-full rounded-xl border border-zinc-200 px-4 py-3 text-sm outline-none transition focus:border-zinc-950"
          />
        </div>

        <div>
          <label for="mensagem" class="text-sm font-medium text-zinc-700">
            Mensagem
          </label>

          <textarea
            id="mensagem"
            name="mensagem"
            rows="5"
            placeholder="Conte um pouco sobre o projeto..."
            class="mt-2 w-full rounded-xl border border-zinc-200 px-4 py-3 text-sm outline-none transition focus:border-zinc-950"
          ></textarea>
        </div>

        <button
          type="submit"
          class="inline-flex items-center justify-center rounded-full bg-zinc-950 px-7 py-4 text-sm font-semibold text-white shadow-lg transition hover:bg-zinc-800"
        >
          Enviar mensagem
        </button>
      </div>
    </form>
  </div>
</section>