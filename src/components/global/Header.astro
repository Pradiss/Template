1 23.1884 18.3459 23.6138 19.735 23.6138C21.1241 23.6138 22.4799 23.1884 23.62 22.3947Z"
              fill="currentColor"></path>
          </svg>

          <span class="text-xl font-bold tracking-tight"> sua marca </span>
        </a>
      </div>
      <div>
        <nav class="hidden lg:block" aria-label="Navegação principal">
          <ul
            class="flex items-center gap-10 text-sm font-medium text-zinc-700"
          >
            <li>
              <a href="#sobre" class="transition hover:text-zinc-950"
                >Sobre nós</a>
            </li>
            <li>
              <a href="#diferenciais" class="transition hover:text-zinc-950"
                >Diferenciais</a>
            </li>
            <li>
              <a href="#servicos" class="transition hover:text-zinc-950"
                >Serviços</a>
            </li>
            <li>
              <a href="#faq" class="transition hover:text-zinc-950">FAQ</a>
            </li>
            <li>
              <a href="#contato" class="transition hover:text-zinc-950"
                >Contato</a>
            </li>
          </ul>
        </nav>
      </div>

      <div class="hidden items-center gap-3 md:flex">
        <a
          href="#contato"
          class="inline-flex items-center justify-center rounded-full bg-zinc-950 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-zinc-950/10 transition hover:bg-zinc-800"
        >
          Fale Conosco
        </a>
      </div>

      <button
        type="button"
        aria-label="Abrir menu"
        aria-expanded="false"
        data-menu-button
        class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-zinc-200 bg-white/70 text-zinc-900 transition hover:bg-white lg:hidden"
      >
        <svg
          data-menu-open-icon
          xmlns="http://www.w3.org/2000/svg"
          class="h-5 w-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M4 7h16M4 12h16M4 17h16"></path>
        </svg>

        <svg
          data-menu-close-icon
          xmlns="http://www.w3.org/2000/svg"
          class="hidden h-5 w-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>

    <div
      data-mobile-menu
      class="mt-3 hidden rounded-3xl border border-zinc-200/70 bg-white/90 p-4 shadow-xl backdrop-blur-xl lg:hidden"
    >
      <nav aria-label="Menu mobile">
        <ul class="space-y-1 text-sm font-medium text-zinc-700">
          <li>
            <a
              href="#sobre"
              class="block rounded-2xl px-4 py-3 transition hover:bg-zinc-100 hover:text-zinc-950"
            >
              Sobre nós
            </a>
          </li>

          <li>
            <a
              href="#diferenciais"
              class="block rounded-2xl px-4 py-3 transition hover:bg-zinc-100 hover:text-zinc-950"
            >
              Diferenciais
            </a>
          </li>

          <li>
            <a
              href="#servicos"
              class="block rounded-2xl px-4 py-3 transition hover:bg-zinc-100 hover:text-zinc-950"
            >
              Serviços
            </a>
          </li>

          <li>
            <a
              href="#faq"
              class="block rounded-2xl px-4 py-3 transition hover:bg-zinc-100 hover:text-zinc-950"
            >
              FAQ
            </a>
          </li>

          <li>
            <a
              href="#contato"
              class="block rounded-2xl px-4 py-3 transition hover:bg-zinc-100 hover:text-zinc-950"
            >
              Contato
            </a>
          </li>
        </ul>

        <a
          href="#contato"
          class="mt-4 inline-flex w-full items-center justify-center rounded-full bg-zinc-950 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-zinc-950/10 transition hover:bg-zinc-800"
        >
          Fale Conosco
        </a>
      </nav>
    </div>
  </div>
</header>

<script>
  const menuButton = document.querySelector("[data-menu-button]");
  const mobileMenu = document.querySelector("[data-mobile-menu]");
  const openIcon = document.querySelector("[data-menu-open-icon]");
  const closeIcon = document.querySelector("[data-menu-close-icon]");
  const mobileLinks = document.querySelectorAll("[data-mobile-menu] a");

  if (
    menuButton instanceof HTMLButtonElement &&
    mobileMenu instanceof HTMLElement &&
    openIcon instanceof SVGElement &&
    closeIcon instanceof SVGElement
  ) {
    const toggleMenu = () => {
      const isOpen = !mobileMenu.classList.contains("hidden");

      mobileMenu.classList.toggle("hidden");
      menuButton.setAttribute("aria-expanded", String(!isOpen));
      openIcon.classList.toggle("hidden");
      closeIcon.classList.toggle("hidden");
    };

    const closeMenu = () => {
      mobileMenu.classList.add("hidden");
      menuButton.setAttribute("aria-expanded", "false");
      openIcon.classList.remove("hidden");
      closeIcon.classList.add("hidden");
    };

    menuButton.addEventListener("click", toggleMenu);

    mobileLinks.forEach((link) => {
      link.addEventListener("click", closeMenu);
    });
  }
</script>
