1 23.1884 18.3459 23.6138 19.735 23.6138C21.1241 23.6138 22.4799 17.4484 23.62 22.3947Z"
              fill="currentColor"
            />
          </svg>

          <span class="text-xl font-bold tracking-tight">
            sua marca
          </span>
        </a>
      </div>

      <nav class="hidden lg:block" aria-label="Navegação principal">
        <ul
          data-header-nav
          class="flex items-center gap-10 text-sm font-medium text-white transition-colors duration-300"
        >
          <li>
            <a href="#sobre" class="transition hover:opacity-70">
              Sobre nós
            </a>
          </li>

          <li>
            <a href="#diferenciais" class="transition hover:opacity-70">
              Diferenciais
            </a>
          </li>

          <li class="group">
            <a href="#servicos" class="transition hover:opacity-70">
              Serviços
            </a>

            <div class="invisible absolute left-0 top-full w-full translate-y-4 pt-6 opacity-0 transition-all duration-300 group-hover:visible group-hover:translate-y-0 group-hover:opacity-100">
              <div class="mx-auto max-w-7xl rounded-[2rem] border border-zinc-200 bg-white p-10 shadow-2xl shadow-zinc-900/10">
                <div class="grid gap-10 lg:grid-cols-[1fr_1.8fr]">
                  <div>
                    <p class="text-xs font-bold uppercase tracking-[0.25em] text-zinc-400">
                      Soluções digitais
                    </p>

                    <h3 class="mt-6 text-3xl font-semibold tracking-tight text-zinc-950">
                      Sites criados para apresentar, convencer e converter.
                    </h3>

                    <p class="mt-4 max-w-md text-sm leading-7 text-zinc-600">
                      Estruturas modernas para empresas que precisam transformar presença digital em contatos reais.
                    </p>

                    <a
                      href="#contato"
                      class="mt-8 inline-flex items-center justify-center rounded-full bg-zinc-950 px-6 py-3 text-sm font-semibold text-white transition hover:bg-zinc-800"
                    >
                      Solicitar orçamento
                    </a>
                  </div>

                  <div class="grid gap-8 border-zinc-200 lg:grid-cols-2 lg:border-l lg:pl-10">
                    <a href="#servicos" class="group/item block">
                      <p class="text-lg font-semibold text-zinc-950 group-hover/item:text-indigo-600">
                        Sites institucionais
                      </p>
                      <p class="mt-2 text-sm leading-6 text-zinc-500">
                        Páginas completas para apresentar empresa, serviços, diferenciais e canais de atendimento.
                      </p>
                    </a>

                    <a href="#servicos" class="group/item block">
                      <p class="text-lg font-semibold text-zinc-950 group-hover/item:text-indigo-600">
                        Landing pages
                      </p>
                      <p class="mt-2 text-sm leading-6 text-zinc-500">
                        Páginas focadas em campanhas, tráfego pago, captação de leads e vendas.
                      </p>
                    </a>

                    <a href="#servicos" class="group/item block">
                      <p class="text-lg font-semibold text-zinc-950 group-hover/item:text-indigo-600">
                        Formulários e WhatsApp
                      </p>
                      <p class="mt-2 text-sm leading-6 text-zinc-500">
                        Estrutura de contato direta para receber orçamentos e iniciar conversas rapidamente.
                      </p>
                    </a>

                    <a href="#servicos" class="group/item block">
                      <p class="text-lg font-semibold text-zinc-950 group-hover/item:text-indigo-600">
                        SEO e performance
                      </p>
                      <p class="mt-2 text-sm leading-6 text-zinc-500">
                        Base técnica organizada, sitemap, carregamento rápido e boa experiência mobile.
                      </p>
                    </a>
                  </div>
                </div>
              </div>
            </div>
          </li>

          <li>
            <a href="#faq" class="transition hover:opacity-70">
              FAQ
            </a>
          </li>

          <li>
            <a href="#contato" class="transition hover:opacity-70">
              Contato
            </a>
          </li>
        </ul>
      </nav>

      <div class="hidden items-center gap-3 md:flex">
        <a
          data-header-cta
          href="#contato"
          class="inline-flex items-center justify-center rounded-full bg-white px-6 py-3 text-sm font-semibold text-zinc-950 shadow-lg shadow-zinc-950/10 transition hover:bg-zinc-200"
        >
          Fale Conosco
        </a>
      </div>

      <button
        type="button"
        aria-label="Abrir menu"
        aria-expanded="false"
        data-menu-button
        class="inline-flex h-11 w-11 items-center justify-center rounded-full text-white transition hover:bg-white/10 lg:hidden"
      >
        <svg
          data-menu-open-icon
          xmlns="http://www.w3.org/2000/svg"
          class="h-5 w-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 7h16M4 12h16M4 17h16" />
        </svg>

        <svg
          data-menu-close-icon
          xmlns="http://www.w3.org/2000/svg"
          class="hidden h-5 w-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <div
      data-mobile-menu
      class="mt-3 hidden rounded-[2rem] border border-zinc-200 bg-white p-5 shadow-2xl shadow-zinc-900/10 lg:hidden"
    >
      <nav aria-label="Menu mobile">
        <ul class="space-y-1 text-sm font-medium text-zinc-700">
          <li>
            <a href="#sobre" class="block rounded-2xl px-4 py-3 transition hover:bg-zinc-100">
              Sobre nós
            </a>
          </li>

          <li>
            <a href="#diferenciais" class="block rounded-2xl px-4 py-3 transition hover:bg-zinc-100">
              Diferenciais
            </a>
          </li>

          <li>
            <button
              type="button"
              data-mobile-services-button
              class="flex w-full items-center justify-between rounded-2xl px-4 py-3 text-left transition hover:bg-zinc-100"
            >
              <span>Serviços</span>
              <span data-mobile-services-icon>+</span>
            </button>

            <div data-mobile-services-menu class="hidden px-4 pb-4 pt-2">
              <div class="grid gap-3">
                <a href="#servicos" class="rounded-2xl bg-zinc-50 p-4">
                  <p class="font-semibold text-zinc-950">Sites institucionais</p>
                  <p class="mt-1 text-sm leading-6 text-zinc-500">Apresente sua empresa com clareza e autoridade.</p>
                </a>

                <a href="#servicos" class="rounded-2xl bg-zinc-50 p-4">
                  <p class="font-semibold text-zinc-950">Landing pages</p>
                  <p class="mt-1 text-sm leading-6 text-zinc-500">Páginas para campanhas e conversão.</p>
                </a>

                <a href="#servicos" class="rounded-2xl bg-zinc-50 p-4">
                  <p class="font-semibold text-zinc-950">SEO e performance</p>
                  <p class="mt-1 text-sm leading-6 text-zinc-500">Estrutura leve, rápida e preparada para o Google.</p>
                </a>
              </div>
            </div>
          </li>

          <li>
            <a href="#faq" class="block rounded-2xl px-4 py-3 transition hover:bg-zinc-100">
              FAQ
            </a>
          </li>

          <li>
            <a href="#contato" class="block rounded-2xl px-4 py-3 transition hover:bg-zinc-100">
              Contato
            </a>
          </li>
        </ul>

        <a
          href="#contato"
          class="mt-4 inline-flex w-full items-center justify-center rounded-full bg-zinc-950 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-zinc-950/10 transition hover:bg-zinc-800"
        >
          Fale Conosco
        </a>
      </nav>
    </div>
  </div>
</header>

<script>
  const header = document.querySelector("[data-header]");
  const headerInner = document.querySelector("[data-header-inner]");
  const headerLogo = document.querySelector("[data-header-logo]");
  const headerNav = document.querySelector("[data-header-nav]");
  const headerCta = document.querySelector("[data-header-cta]");
  const menuButton = document.querySelector("[data-menu-button]");

  const updateHeaderOnScroll = () => {
    const isScrolled = window.scrollY > 40;

    if (
      header instanceof HTMLElement &&
      headerInner instanceof HTMLElement &&
      headerLogo instanceof HTMLElement &&
      headerNav instanceof HTMLElement &&
      headerCta instanceof HTMLElement &&
      menuButton instanceof HTMLButtonElement
    ) {
      header.classList.toggle("bg-white", isScrolled);
      header.classList.toggle("shadow-sm", isScrolled);
      header.classList.toggle("py-2", isScrolled);
      header.classList.toggle("py-4", !isScrolled);

      headerInner.classList.toggle("h-16", isScrolled);
      headerInner.classList.toggle("h-20", !isScrolled);

      headerLogo.classList.toggle("text-zinc-950", isScrolled);
      headerLogo.classList.toggle("text-white", !isScrolled);

      headerNav.classList.toggle("text-zinc-700", isScrolled);
      headerNav.classList.toggle("text-white", !isScrolled);

      headerCta.classList.toggle("bg-zinc-950", isScrolled);
      headerCta.classList.toggle("text-white", isScrolled);
      headerCta.classList.toggle("bg-white", !isScrolled);
      headerCta.classList.toggle("text-zinc-950", !isScrolled);

      menuButton.classList.toggle("text-zinc-950", isScrolled);
      menuButton.classList.toggle("text-white", !isScrolled);
      menuButton.classList.toggle("hover:bg-zinc-100", isScrolled);
      menuButton.classList.toggle("hover:bg-white/10", !isScrolled);
    }
  };

  updateHeaderOnScroll();
  window.addEventListener("scroll", updateHeaderOnScroll);

  const mobileMenu = document.querySelector("[data-mobile-menu]");
  const openIcon = document.querySelector("[data-menu-open-icon]");
  const closeIcon = document.querySelector("[data-menu-close-icon]");
  const mobileLinks = document.querySelectorAll("[data-mobile-menu] a");

  if (
    menuButton instanceof HTMLButtonElement &&
    mobileMenu instanceof HTMLElement &&
    openIcon instanceof SVGElement &&
    closeIcon instanceof SVGElement
  ) {
    const toggleMenu = () => {
      const isOpen = !mobileMenu.classList.contains("hidden");

      mobileMenu.classList.toggle("hidden");
      menuButton.setAttribute("aria-expanded", String(!isOpen));
      openIcon.classList.toggle("hidden");
      closeIcon.classList.toggle("hidden");
    };

    const closeMenu = () => {
      mobileMenu.classList.add("hidden");
      menuButton.setAttribute("aria-expanded", "false");
      openIcon.classList.remove("hidden");
      closeIcon.classList.add("hidden");
    };

    menuButton.addEventListener("click", toggleMenu);

    mobileLinks.forEach((link) => {
      link.addEventListener("click", closeMenu);
    });
  }

  const mobileServicesButton = document.querySelector("[data-mobile-services-button]");
  const mobileServicesMenu = document.querySelector("[data-mobile-services-menu]");
  const mobileServicesIcon = document.querySelector("[data-mobile-services-icon]");

  if (
    mobileServicesButton instanceof HTMLButtonElement &&
    mobileServicesMenu instanceof HTMLElement &&
    mobileServicesIcon instanceof HTMLElement
  ) {
    mobileServicesButton.addEventListener("click", () => {
      const isOpen = !mobileServicesMenu.classList.contains("hidden");

      mobileServicesMenu.classList.toggle("hidden");
      mobileServicesIcon.textContent = isOpen ? "+" : "−";
    });
  }
</script>